# --- Required ---------------------------------------------------------------
GROQ_API_KEY=your-groq-api-key-here

# --- Filesystem (Docker-ready: point this at a mounted volume later) --------
EDU_RAG_DATA_DIR=./data

# --- Server / CORS ------------------------------------------------------------
API_CORS_ORIGINS=*
LOG_LEVEL=INFO

# --- OCR ----------------------------------------------------------------------
OCR_LANG=ben+eng
OCR_DPI=300

# --- Chunking -------------------------------------------------------------------
MIN_CHUNK_TOKENS=350
MAX_CHUNK_TOKENS=700
CHUNK_OVERLAP_RATIO=0.10

# --- Embeddings -----------------------------------------------------------------
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DIM=1024

# --- Reranker / adaptive context depth -------------------------------------------
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANK_TOP_K_SIMPLE=3
RERANK_TOP_K_COMPLEX=6
MAX_NEIGHBORS_SIMPLE=0
MAX_NEIGHBORS_COMPLEX=2
EXCERPT_MAX_WORDS=220
NEIGHBOR_MAX_WORDS=100

# --- Retrieval ------------------------------------------------------------------
DENSE_TOP_K=25
SPARSE_TOP_K=25
RRF_K=60
FUSED_CANDIDATE_K=25

# --- LLM (Groq) -------------------------------------------------------------------
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=700
GROQ_MAX_TOKENS_ANALYSIS=700
GROQ_MAX_TOKENS_HYDE=150
GROQ_MAX_TOKENS_VALIDATE=200

# --- Session --------------------------------------------------------------------
SESSION_MAX_TURNS=5

# --- Chroma collection name -------------------------------------------------------
CHROMA_COLLECTION_NAME=edu_rag_chunks
